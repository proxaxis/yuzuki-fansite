---
import '@/styles/global.scss';
import Layout from '@/layouts/Layout.astro';
import AppHeader from '@/components/AppHeader.vue';
import UserAuth from '@/components/UserAuth.vue';
---
<Layout title="柚月 - YUZUKI > MEMBER" description="柚月の会員ページです。連絡先の登録ができます。">
  <AppHeader client:load />

  <main>
    <section id="member">
      <h2>MEMBER</h2>
      <UserAuth client:only="vue" />
    </section>
  </main>
</Layout>

<style lang="scss">
  @use '../styles/global.scss' as *;

  main {
    min-height: 100vh;

    section {
      padding: 5rem 1rem;
      text-align: center;

      h2 {
        font-family: 'Montserrat', sans-serif;
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--blue-1);
        margin-bottom: 40px;
        letter-spacing: 0.15em;
        position: relative;
        display: inline-block;

        &::after {
          content: '';
          position: absolute;
          bottom: -10px;
          left: 50%;
          transform: translateX(-50%);
          width: 24px;
          height: 6px;
          border-radius: 3px;
          background-color: var(--accent);
        }
      }
    }
  }
</style>
